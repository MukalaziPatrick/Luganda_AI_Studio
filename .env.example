# ====================================================
# Luganda AI Studio — Environment Variables Example
# ====================================================
# Copy this file and rename it to .env
# Fill in real values in .env
# NEVER commit .env to version control
# .env.example is safe to commit — it contains no secrets
# ====================================================

# --- Application ---
APP_NAME=Luganda AI Studio
APP_VERSION=0.1.0
ENVIRONMENT=development

# --- Server ---
HOST=127.0.0.1
PORT=8000
RELOAD=True

# --- API Keys ---
# Get your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- CORS Origins ---
# Add your frontend URL here if it differs from the defaults
# ALLOWED_ORIGINS=["http://localhost:5173"]

# --- Dataset paths ---
DATASETS_DIR=datasets

# --- OpenRouter (optional — add key when ready) ---
# Get a key at https://openrouter.ai/keys
# When set, OpenRouter becomes the primary neural translation fallback (Pass 3).
# When absent, the pipeline falls back to the local NLLB-200 model instead.
# OPENROUTER_API_KEY=sk-or-...

# Optional: override the model (default: google/gemma-2-9b-it:free)
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Optional: timeout in seconds before falling back to NLLB-200 (default: 8)
# OPENROUTER_TIMEOUT_SECONDS=8

# Optional: daily spend cap in USD for paid models (default: 0.10)
# OPENROUTER_DAILY_LIMIT_USD=0.10